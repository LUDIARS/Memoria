# Electron build outputs
dist/
out/
out-scripts/
node_modules/
.cache/
*.tsbuildinfo

# Bundle output — populated by scripts/bundle-server.mjs at build time.
# Keep the empty dirs (.gitkeep) so the layout exists in fresh checkouts;
# electron-builder's extraResources will copy them into the installer.
resources/server/*
!resources/server/.gitkeep
resources/node/*
!resources/node/.gitkeep

# Generated icons — keep .gitkeep so README + icon source pointers stay
# in tree, but treat the rasterised assets as build artefacts.
icons/32x32.png
icons/128x128.png
icons/128x128@2x.png
icons/256x256.png
icons/512x512.png
icons/icon.png
icons/icon.ico
icons/icon.icns
