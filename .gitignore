# dependencies
node_modules/

# local environment overrides
.env
.env.local
# Infisical machine identity (= Infisical に到達するための bootstrap 認証情報)。
# アプリ設定値そのものは Infisical 本体に置く。 この .env.secrets だけは
# Infisical に入れられない (chicken-and-egg) のでファイルで持つ。
.env.secrets

# user data — never commit
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# logs / artifacts
*.log
.DS_Store
Thumbs.db

# editor
.vscode/
.idea/
*.swp

# misc test artifacts
test-payload.json
