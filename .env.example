# Memoria 環境変数 — このファイルをコピーして .env を作成し、必要な行だけ設定してください。
#
#   cp .env.example .env
#   # → 編集
#   cd server && npm start         # .env / ../.env を自動で読み込みます (Node 21.7+)
#
# 既定値で問題ない場合は何も設定しなくて構いません。
# インラインで渡した環境変数 (例: MEMORIA_PORT=6000 npm start) が .env より優先されます。

# ─────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────

# HTTP サーバーがリッスンするポート (既定 5180)
# MEMORIA_PORT=5180

# DB と HTML 保存先のディレクトリ (既定: <repo>/data)
# MEMORIA_DATA=E:/Document/Ars/Memoria/data

# ─────────────────────────────────────────────────────────────────────────
# Claude CLI
# ─────────────────────────────────────────────────────────────────────────

# claude バイナリのパス (PATH 上にある場合は不要)
# MEMORIA_CLAUDE_BIN=claude

# Windows: claude が要求する git-bash の bash.exe 絶対パス。
# PATH に claude があっても、Node の spawn() 経由で起動すると必要になります。
# CLAUDE_CODE_GIT_BASH_PATH=C:\Program Files\Git\bin\bash.exe

# ─────────────────────────────────────────────────────────────────────────
# RAG (semantic search + Q&A)
# ─────────────────────────────────────────────────────────────────────────

# RAG 機能のオン/オフ。0 にすると埋め込み生成と /api/search /api/ask が無効化されます。
# MEMORIA_RAG=1

# ─────────────────────────────────────────────────────────────────────────
# Mode (local / online)
# ─────────────────────────────────────────────────────────────────────────

# local (既定): 単一ユーザー、認証なし、全エンドポイント解放、訪問履歴あり
# online      : 多ユーザー、Authorization: Bearer <JWT> 必須、/api/visits/* は 403、
#               /api/access はノーオペ、ブックマークは user_id でスコープ
# MEMORIA_MODE=local

# online モード時の JWT (HS256) 検証用シークレット。
# 本番では Cernere `@ludiars/cernere-service-adapter` の SERVICE_JWT_SECRET と同じ値を使う。
# MEMORIA_JWT_SECRET=change-me-very-long-random-string

# ─────────────────────────────────────────────────────────────────────────
# Content filter (NG / R18)
# ─────────────────────────────────────────────────────────────────────────

# NG ワード/ドメインの追加リスト (既定値はソース内、外部ファイルでマージ可)
# 1 行 1 語 (# でコメント) または JSON 配列。
# MEMORIA_NGWORDS_FILE=./ngwords.txt
# MEMORIA_NG_DOMAINS_FILE=./ngdomains.txt

# 0 にすると NG フィルタを完全に無効化。
# MEMORIA_CONTENT_FILTER=1

# ─────────────────────────────────────────────────────────────────────────
# MCP server (mcp-server/)
# ─────────────────────────────────────────────────────────────────────────

# MCP サーバーから叩く Memoria HTTP API の URL
# MEMORIA_URL=http://localhost:5180
